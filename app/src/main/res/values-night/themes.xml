<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme for Dark Mode. -->
    <style name="Base.Theme.Final_Lab_Mobile" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Material 3 Color Palette (Dark) -->
        <item name="colorPrimary">@color/brand_primary_dark</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorPrimaryContainer">@color/brand_secondary_dark</item>
        <item name="colorOnPrimaryContainer">@color/white</item>

        <item name="android:windowBackground">@color/surface_dark</item>
        <item name="colorSurface">@color/surface_card_dark</item>
        <item name="colorOnSurface">@color/text_main_dark</item>
        <item name="colorSurfaceVariant">@color/surface_dark</item>
        <item name="colorOnSurfaceVariant">@color/text_muted_dark</item>
        <item name="colorOutline">@color/border_color_dark</item>
        <item name="colorOutlineVariant">@color/border_color_dark</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Typography -->
        <item name="textAppearanceTitleLarge">@style/TextAppearance.App.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.App.TitleMedium</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.App.BodyMedium</item>
    </style>
</resources>